# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/feedbackos?schema=public"

# ─────────────────────────────────────────────
# REDIS (Upstash or local)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# OPENROUTER
# ─────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."

# ─────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# EMAIL (Resend for magic links + alerts)
# ─────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@feedbackos.app"

# ─────────────────────────────────────────────
# ZENDESK
# ─────────────────────────────────────────────
ZENDESK_SUBDOMAIN=""
ZENDESK_API_TOKEN=""
ZENDESK_EMAIL=""

# ─────────────────────────────────────────────
# INTERCOM
# ─────────────────────────────────────────────
INTERCOM_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────
# ENCRYPTION (AES-256) — generate: openssl rand -hex 32
# ─────────────────────────────────────────────
ENCRYPTION_KEY=""

# ─────────────────────────────────────────────
# WORKER
# ─────────────────────────────────────────────
WORKER_CONCURRENCY="5"
